test compile precise-output
target x86_64

function %f0(i32) -> i32 {
    sig0 = (i32) -> f32 tail
    fn0 = %g(i32) -> f32 tail

    block0(v1: i32):
        v2 = f64const 0x1.0
        try_call fn0(v1), sig0, block1(ret0, v2), []

    block1(v3: f32, v4: f64):
        v5 = iconst.i32 1
        return v5
}

; test